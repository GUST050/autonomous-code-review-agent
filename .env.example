
# Autonomous Code Review Agent - Environment Variables

# LLM API Keys (fyll i minst 2 st)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROK_API_KEY=...

# LangSmith
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=autonomous-code-review

# GitHub Integration
GITHUB_TOKEN=ghp_...

# Model Settings 
MODEL_TIER_ANALYSIS=grok-4-mini      # billig modell för analys
MODEL_TIER_CODING=claude-3-5-sonnet  # stark modell för kod och fixes
TEMPERATURE=0.2
MAX_ITERATIONS=5
