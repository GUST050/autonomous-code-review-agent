# ========================================
# API Keys för Autonomous Code Review Agent
# ========================================

# LLM API-nycklar (fyll i minst 2 st)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROK_API_KEY=...

# LangSmith - för att se vad agenterna gör (rekommenderas)
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=autonomous-code-review

# GitHub - för att kunna läsa och skriva till PR:er
GITHUB_TOKEN=ghp_...

# Inställningar
MODEL_TIER_ANALYSIS=grok-4-mini
MODEL_TIER_CODING=claude-3-5-sonnet
TEMPERATURE=0.2
MAX_ITERATIONS=5
